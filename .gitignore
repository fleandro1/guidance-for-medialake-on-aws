# Visual-testing scratch artifacts (Playwright harness output, provisioning
# scripts, screenshots, traces). Not part of the product; may contain
# credentials/tokens — must never be committed.
.vistest/
medialake_user_interface/.vistest/
medialake_user_interface/vistest-report/
medialake_user_interface/vistest-results/
medialake_user_interface/tests/vistest/
medialake_user_interface/playwright.vistest.config.ts

# Browser-driven QA (medialake-qa skill)
# Run outputs (reports + screenshots) and isolated browser-session dirs.
# .qa-sessions can hold browser auth/localStorage state — must never be committed.
qa/
.qa-sessions/


# MediaLake QA run outputs (screenshots + reports) — not source
qa/results/

# CI native-layer build cache (moved here by .cicd/build_lambdas.py clean step).
# Contains vendored native libs (pyvips/libvips, OpenEXR, numpy, etc.). Must NOT
# be tracked: formatters (isort/black) reordering vendored package imports here
# corrupted pyvips and broke image proxy/thumbnail at runtime. Always rebuilt by
# the .cicd/build_*.sh scripts, so it is safe to ignore.
.preserve_layers/
